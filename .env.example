# Βάση δεδομένων. Στο Docker Compose ορίζεται αυτόματα.
DATABASE_URL=postgresql+psycopg://tenders:tenders@postgres:5432/tenders

# ΚΗΜΔΗΣ Open Data API
KHMDHS_BASE_URL=https://cerpp.eprocurement.gov.gr
KHMDHS_TIMEOUT_SECONDS=45
KHMDHS_MAX_PAGES=100
# Πιο ήπιο ingest προς ΚΗΜΔΗΣ, ειδικά όταν profile έχει broad parent CPV με πολλά παιδιά.
KHMDHS_PAGE_DELAY_SECONDS=1.0
KHMDHS_RATE_LIMIT_RETRIES=4
KHMDHS_RATE_LIMIT_BASE_DELAY_SECONDS=5.0
ENABLE_DIAVGEIA_RSS=false
DIAVGEIA_BASE_URL=https://diavgeia.gov.gr/luminapi/opendata
DIAVGEIA_TIMEOUT_SECONDS=30
DIAVGEIA_DEFAULT_PAGE_SIZE=10

# Scheduler: καθημερινή εισαγωγή.
SCHEDULE_HOUR=7
SCHEDULE_MINUTE=15
INGEST_DAYS_BACK=3
MATCH_THRESHOLD=55
# Legacy flags. Το τωρινό ingest είναι metadata-first και δεν κατεβάζει PDFs μαζικά.
FETCH_PDF_FOR_SCORE_ABOVE=40
AUTO_FETCH_PDF_TEXT=false

# Ζώνη ώρας εμφάνισης στο UI και στις αναφορές. Για Ελλάδα αφήστε Europe/Athens.
APP_TIMEZONE=Europe/Athens

# Προαιρετικό basic auth για web interface. Βάλτε τιμές πριν το δώσετε σε πελάτη.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# User-oriented login. SESSION_SECRET_KEY signs browser sessions.
# On first startup with an empty user table, BOOTSTRAP_ADMIN_* creates the first admin.
SESSION_SECRET_KEY=
SESSION_MAX_AGE_SECONDS=86400
ALLOW_LOCAL_ADMIN_FALLBACK=false
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_EMAIL=

# Προαιρετικό email digest.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
DIGEST_RECIPIENTS=
